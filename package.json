{
  "name": "uni-admin",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "test": "vitest run",
    "typecheck": "bunx tsc -b --noEmit",
    "postinstall": "nuxt prepare",
    "lint": "run-s --continue-on-error lint:oxlint lint:eslint",
    "lint:oxlint": "oxlint --type-aware",
    "lint:eslint": "eslint .",
    "fix": "run-s --continue-on-error fix:oxlint fix:eslint",
    "fix:oxlint": "oxlint --type-aware --fix --fix-suggestions",
    "fix:eslint": "eslint . --fix"
  },
  "dependencies": {
    "@electric-sql/pglite": "^0.4.5",
    "@nuxt/eslint": "1.15.2",
    "@pinia/nuxt": "0.11.3",
    "@tailwindcss/vite": "^4.3.0",
    "dotenv": "^17.4.2",
    "kysely": "^0.29.2",
    "nuxt": "^4.4.5",
    "pg": "^8.20.0",
    "pinia": "^3.0.4",
    "tailwindcss": "^4.3.0",
    "vue": "^3.5.34",
    "vue-router": "^5.0.6",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@nuxt/test-utils": "^4.0.3",
    "@types/bun": "^1.3.14",
    "@types/pg": "^8.20.0",
    "@vue/test-utils": "^2.4.10",
    "eslint": "^10.4.0",
    "eslint-plugin-oxlint": "^1.66.0",
    "eslint-plugin-unicorn": "^64.0.0",
    "npm-run-all": "^4.1.5",
    "oxlint": "^1.64.0",
    "oxlint-tsgolint": "^0.23.0",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tsx": "^4.22.0",
    "vitest": "^4.1.7"
  }
}
